{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "email": "email dev",
    "test:functions": "npm test --silent --prefix functions",
    "check:prod": "npm run -s typecheck && npm run -s test:functions && node scripts/check-production.mjs",
    "set:matching:low-demand": "node scripts/set-matching-settings.mjs --manualBoardEnabled=true --highDemandPeriod=false",
    "set:matching:high-demand": "node scripts/set-matching-settings.mjs --manualBoardEnabled=false --highDemandPeriod=true",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:functions": "npm run -s build --prefix functions && firebase deploy --only functions",
    "deploy:app": "firebase deploy --only hosting",
    "deploy:all": "npm run -s check:prod && npm run -s deploy:rules && npm run -s deploy:functions && npm run -s deploy:app"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-email/components": "^0.3.2",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "firebase": "^12.4.0",
    "firebase-admin": "^12.1.0",
    "lucide-react": "^0.475.0",
    "next": "15.5.9",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-email": "^4.2.3",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "resend": "^3.2.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
