# -----------------------------------------------------------------------------
# Local development .env.example
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# -----------------------------------------------------------------------------

# Client-side Firebase config (from Firebase Console > Project settings > Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Where the app is running. Used for verification/reset email links.
# Dev: http://localhost:3000   Prod: https://campus-connections.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: comma-separated list of non-university emails allowed to sign up
NEXT_PUBLIC_EMAIL_WHITELIST=

# -------- Admin SDK (server routes) --------
# Option A (simplest): paste the entire service-account JSON from
# Firebase Console > Project settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: individual fields (only set if NOT using FIREBASE_SERVICE_ACCOUNT_JSON)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# -------- SMTP (optional: used only by Next.js API routes) --------
# Match-notification emails live in Firebase Functions; configure those in
# `functions/.env` OR via `firebase functions:secrets:set`.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
