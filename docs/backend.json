
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Firebase Authentication UID"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "university": {
          "type": "string"
        },
        "campusArea": {
          "type": "string"
        },
        "photoUrl": {
          "type": "string",
          "format": "uri"
        },
        "emailVerified": {
          "type": "boolean"
        },
        "gender": {
          "type": "string",
          "enum": [
            "Male",
            "Female",
            "Other",
            "Prefer not to say"
          ]
        },
        "dateOfBirth": {
          "type": "string",
          "format": "date-time"
        },
        "flaggedUserIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "isBanned": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "university",
        "gender",
        "dateOfBirth"
      ]
    },
    "TripRequest": {
      "title": "Trip Request",
      "description": "A user's request for a shared ride.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "matched",
            "cancelled",
            "completed"
          ]
        },
        "matchId": {
          "type": "string",
          "description": "ID of the match document in the /matches collection"
        }
      },
      "required": [
        "id",
        "userId",
        "status"
      ]
    },
    "Match": {
      "title": "Match",
      "description": "Represents a confirmed match between two users.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "participantIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array containing the two matched user IDs."
        },
        "tripRequestIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array containing the two matched trip request IDs."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "participants": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "userPhotoUrl": { "type": "string", "format": "uri" },
              "university": { "type": "string" },
              "flightCode": { "type": "string" },
              "flightDateTime": { "type": "string", "format": "date-time" }
            },
            "required": ["userName", "university", "flightCode", "flightDateTime"]
          },
          "description": "An object where keys are user IDs and values are their denormalized trip details."
        }
      },
      "required": ["id", "participantIds", "tripRequestIds", "createdAt", "participants"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message within a chat.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "senderId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "text",
        "senderId"
      ]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session between two users.",
      "type": "object",
      "properties": {
        "userIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "auth": {
    "providers": [
      "email-password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores public profiles for all users."
    },
    "/tripRequests/{tripId}": {
      "schema": {
        "$ref": "#/entities/TripRequest"
      },
      "description": "Collection of all trip requests from users."
    },
    "/matches/{matchId}": {
      "schema": {
        "$ref": "#/entities/Match"
      },
      "description": "Stores details of a confirmed match between two users."
    },
    "/chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/Chat"
      },
      "description": "Contains metadata for chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/ChatMessage"
      },
      "description": "Sub-collection storing messages for a specific chat."
    }
  }
}
