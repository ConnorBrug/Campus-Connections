# -----------------------------
# Client Firebase (required)
# -----------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# -----------------------------
# Base URL (REQUIRED in production)
# Used by verification / password-reset emails as the return URL.
# -----------------------------
NEXT_PUBLIC_BASE_URL=https://campus-connections.com

# -----------------------------
# Optional email whitelist (comma-separated)
# Example: test1@gmail.com,test2@gmail.com
# -----------------------------
NEXT_PUBLIC_EMAIL_WHITELIST=

# -----------------------------
# Firebase Admin credentials (required for server routes)
# Option A: single JSON
# -----------------------------
FIREBASE_SERVICE_ACCOUNT_JSON=

# -----------------------------
# Firebase Admin credentials (Option B: split fields)
# Use this only if not using FIREBASE_SERVICE_ACCOUNT_JSON
# -----------------------------
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# -----------------------------
# SMTP (recommended for email notifications)
# -----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
