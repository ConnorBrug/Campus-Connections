/**
 * @fileoverview Firestore Security Rules for Ride Sharing App
 *
 * Core Philosophy:
 * This ruleset prioritizes user data protection by enforcing strict ownership for user profiles and ride requests.
 * Ride matches are secured through a shared access model, allowing only matched users to read match details and associated chats.
 * Public read access is granted for trip requests.
 *
 * Data Structure:
 * - /users/{userId}: Stores public user profile information.
 * - /tripRequests/{tripId}: Contains ride requests. Each request includes the userId of the requester.
 * - /matches/{matchId}: Holds data for confirmed ride matches, including participant user IDs and denormalized trip details.
 * - /chats/{chatId}: Stores metadata for chat sessions.
 * - /chats/{chatId}/messages/{messageId}: Sub-collection storing chat messages for a specific chat.
 *
 * Key Security Decisions:
 * - User profiles are self-owned; users can only read/write their own profiles.
 * - Listing all users is disallowed to protect user privacy.
 * - Trip requests can be created by authenticated users with the correct userId.
 * - Only matched users can read ride match details and chat messages.
 * - The rules do NOT perform extensive data validation beyond essential authorization checks for prototyping speed.
 *
 * Denormalization for Authorization:
 * - The /matches/{matchId} document contains a `participantIds` array. This denormalization allows security rules to quickly verify if a user is part of a match without needing additional `get()` calls.
 *
 * Structural Segregation:
 * - Uses separate collections for public and private data.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the requesting user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the requesting user owns the document.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an existing owner of the resource.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }


    /**
     * @description Rules for user profiles. Users can only read and write their own profile. Listing all users is disallowed.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own profile.
     *     request.auth.uid: "user123"
     *     userId: "user123"
     * @allow (get) - Authenticated user reads their own profile.
     *     request.auth.uid: "user123"
     *     userId: "user123"
     * @deny (create) - Authenticated user attempts to create a profile with a mismatched ID.
     *     request.auth.uid: "user123"
     *     userId: "user456"
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for ride requests.  Authenticated users can create ride requests, and read their own ride requests.
     * @path /tripRequests/{tripId}
     * @allow (create) - Authenticated user creates a ride request for themselves.
     *     request.auth.uid: "user123"
     *     request.resource.data.userId: "user123"
     * @allow (get) - Authenticated user gets their own ride request.
     *     request.auth.uid: "user123"
     *     resource.data.userId: "user123"
     * @deny (create) - Authenticated user attempts to create a ride request for another user.
     *     request.auth.uid: "user123"
     *     request.resource.data.userId: "user456"
     * @principle Enforces document ownership for writes.
     */
    match /tripRequests/{tripId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn()
        && request.query.where('userId', '==', request.auth.uid)
        && request.query.where('status', 'in', ["pending", "matched", "completed"]);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Rules for ride matches. Only users present in the `participantIds` array can read or write to match details.
     * @path /matches/{matchId}
     * @allow (get) - Authenticated user who is a participant in the match reads the match details.
     *     request.auth.uid: "user123"
     *     resource.data.participantIds: ["user123", "user456"]
     * @deny (get) - Authenticated user who is not a participant attempts to read the match details.
     *     request.auth.uid: "user789"
     *     resource.data.participantIds: ["user123", "user456"]
     * @principle Restricts access to ride matches to participating users.
     */
    match /matches/{matchId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow list: if false;
      allow create: if false;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;
    }

    /**
     * @description Rules for chat sessions.  Only users who are part of the chat (defined in `userIds`) can read the chat metadata.
     * @path /chats/{chatId}
     * @allow (get) - Authenticated user who is a participant in the chat reads the chat metadata.
     *     request.auth.uid: "user123"
     *     resource.data.userIds: ["user123", "user456"]
     * @deny (get) - Authenticated user who is not a participant attempts to read the chat metadata.
     *     request.auth.uid: "user789"
     *     resource.data.userIds: ["user123", "user456"]
     * @principle Restricts access to chats to participating users.
     */
    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.userIds;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

        /**
         * @description Rules for chat messages. Only users who are part of the chat can read messages.
         * @path /chats/{chatId}/messages/{messageId}
         *  @allow (get) - Authenticated user who is a participant in the chat can read the chat messages.
         *     request.auth.uid: "user123"
         *     resource.data.userIds: ["user123", "user456"]
         * @deny (get) - Authenticated user who is not a participant in the chat attempts to read the chat messages.
         *     request.auth.uid: "user789"
         *     resource.data.userIds: ["user123", "user456"]
         * @principle Restricts access to chat messages to participating users.
         */
        match /messages/{messageId} {
          allow get: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.userIds;
          allow list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.userIds;
          allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.userIds;
          allow update: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.userIds;
          allow delete: if false;
        }
    }
  }
}