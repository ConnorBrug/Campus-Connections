rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (create) If the user ID in the path matches the authenticated user's ID, allowing self-creation.
     * @allow (get, list) Anyone can read user profiles.
     * @allow (update, delete) Only the user who owns the profile can update or delete it.
     * @deny (create) If the user ID in the path does not match the authenticated user's ID.
     * @deny (update, delete) If the user does not own the profile.
     * @principle Enforces document ownership for writes and public read access.
     */
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow get, list: if true;
      allow update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Controls access to trip requests.
     * @path /tripRequests/{tripId}
     * @allow (create) Only the authenticated user can create a trip request with their own user ID.
     * @allow (get) Only the owner of the trip request can read it.
     * @allow (list) Only the owner can list their own trip requests with specific status filters.
     * @deny (create) If the authenticated user's ID does not match the userId in the request data.
     * @deny (get) If the requesting user is not the owner of the trip request.
     * @deny (list) If the query does not filter by the authenticated user's ID and specific statuses.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /tripRequests/{tripId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && request.query.where("userId", "==", request.auth.uid).where("status", "in", ["pending", "matched", "completed"]).size() == 2;
      allow update, delete: if false; // Not Implemented
    }

    /**
     * @description Controls access to matches.
     * @path /matches/{matchId}
     * @allow (create) Not implemented in this phase.
     * @allow (get) If the authenticated user is one of the participants.
     * @allow (list) Not implemented in this phase.
     * @allow (update, delete) Not implemented in this phase.
     * @deny (create) Always deny.
     * @deny (get) If the authenticated user is not a participant.
     * @principle Enforces shared access between participants.
     */
    match /matches/{matchId} {
      allow create: if false;
      allow get: if isSignedIn() && resource.data.participantIds.hasAny([request.auth.uid]);
      allow list: if false;
      allow update, delete: if false; // Not Implemented
    }

    /**
     * @description Controls access to chats.
     * @path /chats/{chatId}
     * @allow (create) Not implemented in this phase.
     * @allow (get) If the authenticated user is one of the users in the chat.
     * @allow (list) Not implemented in this phase.
     * @allow (update, delete) Not implemented in this phase.
     * @deny (create) Always deny.
     * @deny (get) If the authenticated user is not a participant.
     * @principle Enforces shared access between chat participants.
     */
    match /chats/{chatId} {
      allow create: if false;
      allow get: if isSignedIn() && resource.data.userIds.hasAny([request.auth.uid]);
      allow list: if false;
      allow update, delete: if false; // Not Implemented

      /**
       * @description Controls access to chat messages.
       * @path /chats/{chatId}/messages/{messageId}
       * @allow (create) If the authenticated user is a participant in the chat.
       * @allow (get, list) If the authenticated user is a participant in the chat.
       * @allow (update, delete) Not implemented in this phase.
       * @deny (create) If the authenticated user is not a participant.
       * @deny (get, list) If the authenticated user is not a participant.
       * @principle Enforces shared access to chat messages.
       */
      match /messages/{messageId} {
        allow create: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userIds.hasAny([request.auth.uid]);
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userIds.hasAny([request.auth.uid]);
        allow update, delete: if false; // Not Implemented
      }
    }
  }
}

/**
 * @description Checks if the user is signed in.
 * @returns {boolean} True if the user is signed in, false otherwise.
 * @principle Ensures that only authenticated users can perform certain actions.
 */
function isSignedIn() {
  return request.auth != null;
}