/**
 * @file Overview
 * This ruleset enforces a user-ownership model for user profiles,
 * shared access for matches, and public read access with owner-only
 * writes for trip requests.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only by the user.
 * - /tripRequests/{tripId}: Stores trip requests, publicly readable but only writable by the user who created them.
 * - /matches/{matchId}: Stores match information, accessible to the two matched users.
 * - /chats/{chatId}: Stores chat metadata.
 * - /chats/{chatId}/messages/{messageId}: Stores individual chat messages, accessible to the participants of the chat.
 *
 * Key Security Decisions:
 * - User profiles are strictly private and only accessible to the owning user.
 * - Trip requests are publicly readable to facilitate discovery but can only be created, updated, or deleted by their owners.
 * - Matches are only accessible to the two users involved in the match.
 * - Chats and their messages are only accessible to the two users involved in the chat.
 * - Listing of users is disallowed to protect user privacy.
 *
 * Denormalization for Authorization:
 * - Matches denormalize participant IDs to allow easy validation of user access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects user profiles, allowing only the user to read and write their own profile.
     * @path /users/{userId}
     * @allow (read, write) User with ID 'user123' can read/write document /users/user123.
     * @deny (read, write) User with ID 'user456' cannot read/write document /users/user123.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Controls access to trip requests, allowing public reads but restricting writes to the owner.
     * @path /tripRequests/{tripId}
     * @allow (read) Any user can read any trip request.
     * @allow (create) User with ID 'user123' can create a trip request with userId 'user123'.
     * @deny (create) User with ID 'user123' cannot create a trip request with userId 'user456'.
     * @allow (update, delete) User with ID 'user123' can update/delete a trip request with userId 'user123', if the document exists.
     * @deny (update, delete) User with ID 'user123' cannot update/delete a trip request with userId 'user456'.
     * @principle Allows public read access while enforcing owner-only writes.
     */
    match /tripRequests/{tripId} {
       function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if true;
      allow list: if true;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if resource != null && isOwner(resource.data.userId);
      allow delete: if resource != null && isOwner(resource.data.userId);
    }

    /**
     * @description Manages access to matches, restricting read and write access to the two matched users.
     * @path /matches/{matchId}
     * @allow (read, write) User 'user123' can read/write match 'match123' if 'user123' is in 'participantIds'.
     * @deny (read, write) User 'user456' cannot read/write match 'match123' if 'user456' is not in 'participantIds'.
     * @principle Implements shared access between collaborators.
     */
    match /matches/{matchId} {
      function isParticipant() {
        return request.auth != null && request.auth.uid in resource.data.participantIds;
      }
      allow get: if isParticipant();
      allow list: if false;
      allow create: if request.auth.uid in request.resource.data.participantIds;
      allow update: if resource != null && isParticipant();
      allow delete: if resource != null && isParticipant();
    }

    /**
     * @description Protects chat metadata, restricting access to the two users involved in the chat.
     * @path /chats/{chatId}
     * @allow (read, write) User 'user123' can read/write chat 'chat123' if 'user123' is in 'userIds'.
     * @deny (read, write) User 'user456' cannot read/write chat 'chat123' if 'user456' is not in 'userIds'.
     * @principle Implements shared access between collaborators.
     */
    match /chats/{chatId} {
      function isChatParticipant() {
        return request.auth != null && request.auth.uid in resource.data.userIds;
      }
      allow get: if isChatParticipant();
      allow list: if false;
      allow create: if request.auth.uid in request.resource.data.userIds;
      allow update: if resource != null && isChatParticipant();
      allow delete: if resource != null && isChatParticipant();

      /**
       * @description Secures chat messages, ensuring only chat participants can read and write messages.
       * @path /chats/{chatId}/messages/{messageId}
       * @allow (read, write) User 'user123' can read/write message 'message123' in chat 'chat123' if 'user123' is a participant in 'chat123'.
       * @deny (read, write) User 'user456' cannot read/write message 'message123' in chat 'chat123' if 'user456' is not a participant in 'chat123'.
       * @principle Enforces shared access for subcollections based on parent document permissions.
       */
      match /messages/{messageId} {
        function isChatParticipant() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.userIds.hasAny([request.auth.uid]);
        }
        allow get: if isChatParticipant();
        allow list: if isChatParticipant();
        allow create: if isChatParticipant();
        allow update: if resource != null && isChatParticipant();
        allow delete: if resource != null && isChatParticipant();
      }
    }
  }
}