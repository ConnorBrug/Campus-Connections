/**
 * @fileoverview Firestore Security Rules for Ride Sharing App.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and trip requests.
 * Matches and Chats implement a shared access model, where only participants can access the data.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only by the user themselves.
 * - /tripRequests/{tripId}: Stores trip requests, accessible only by the user who created them.
 * - /matches/{matchId}: Stores match details, accessible only by the matched participants.  Includes denormalized user data.
 * - /chats/{chatId}: Stores metadata for chat sessions.
 * - /chats/{chatId}/messages/{messageId}: Sub-collection storing messages for a specific chat.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data.
 * - Users can only create, update, and delete their own trip requests.
 * - Only participants of a match can access the match details.
 * - Only participants of a chat can send and receive messages within that chat.
 * - Listing of users and trip requests is disallowed to prevent information leakage.
 *
 * Denormalization for Authorization:
 * - The `/matches/{matchId}` documents denormalize user data (participantIds) to allow efficient security rules without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description: Secures user profiles, allowing only the owner to read and write.
     * @path: /users/{userId}
     * @allow: User 'user123' (get, update) their profile.
     * @deny: User 'user456' (get, update) user 'user123' profile.
     * @principle: Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description: Secures trip requests, allowing only the owner to read, create, update, and delete.
     * @path: /tripRequests/{tripId}
     * @allow: User 'user123' (create, get, update, delete) their trip request.
     * @deny: User 'user456' (create, get, update, delete) user 'user123' trip request.
     * @principle: Enforces document ownership for all operations.
     */
    match /tripRequests/{tripId} {
      allow get: if request.auth.uid == resource.data.userId;
      allow list: if false;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId;
    }

    /**
     * @description: Secures matches, allowing only participants to read and write.
     * @path: /matches/{matchId}
     * @allow: User 'user123' (get, update) match if 'user123' is in 'participantIds'.
     * @deny: User 'user456' (get, update) match if 'user456' is not in 'participantIds'.
     * @principle: Enforces shared access between matched participants.
     */
    match /matches/{matchId} {
      allow get: if request.auth.uid in resource.data.participantIds;
      allow list: if false;
      allow create: if request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth.uid in resource.data.participantIds;
      allow delete: if false;
    }

    /**
     * @description: Secures chats, allowing only participants to read and write.
     * @path: /chats/{chatId}
     */
    match /chats/{chatId} {
      allow get: if request.auth.uid in resource.data.userIds;
      allow list: if false;
      allow create: if request.auth.uid in request.resource.data.userIds;
      allow update: if request.auth.uid in resource.data.userIds;
      allow delete: if false;


      /**
       * @description: Secures chat messages, allowing only chat participants to read and write.
       * @path: /chats/{chatId}/messages/{messageId}
       */
      match /messages/{messageId} {
        allow get: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.userIds;
        allow list: if false;
        allow create: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.userIds;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}