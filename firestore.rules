rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }

    /* -------- USERS (owner read; constrained owner update) --------
       Owners may edit ONLY their self-service profile fields. Security/
       moderation-controlled fields (isBanned, flaggedUserIds, synthetic)
       and identity fields (email, university) are frozen at the rule level
       and may be written only via the Admin SDK (server routes / functions),
       which bypasses these rules. This prevents ban-evasion (self-unban),
       school-spoofing, and tampering with the dev `synthetic` flag. */
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || request.auth.token.admin == true);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['name', 'campusArea', 'gender', 'graduationYear', 'photoUrl', 'emailVerified', 'authProvider'])
                    && (!('isBanned' in request.resource.data) || request.resource.data.isBanned == resource.data.isBanned)
                    && (!('flaggedUserIds' in request.resource.data) || request.resource.data.flaggedUserIds == resource.data.flaggedUserIds)
                    && (!('synthetic' in request.resource.data) || request.resource.data.synthetic == resource.data.synthetic)
                    && (!('email' in request.resource.data) || request.resource.data.email == resource.data.email)
                    && (!('university' in request.resource.data) || request.resource.data.university == resource.data.university);
      allow delete: if false;
    }

    /* -------- TRIPS (server-managed writes; owner-gated read) --------
       All trip writes go through the Admin SDK (POST /api/trips, the
       cancel/delay/manual-match routes, and the matching Cloud Functions),
       which bypass these rules. Clients are read-only so they cannot skip
       the server-side sanitization, ban checks, bag-limit caps, and
       server-derived identity fields. */
    match /tripRequests/{id} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow create, update, delete: if false;
    }

    /* -------- GROUPS (server-managed) -------- */
    match /rideGroups/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /* -------- MATCHES (server-managed; participant-gated read) --------
       Matches are written exclusively by the matching Cloud Functions via
       the Admin SDK (which bypasses these rules). Clients read their own
       match docs from chat/planned-trips/match-found. Admin claim can read
       all matches so the dev-only matching dashboard works. */
    match /matches/{id} {
      allow read: if isSignedIn()
                  && (request.auth.token.admin == true
                      || request.auth.uid in resource.data.participantIds);
      allow write: if false;
    }

    /* -------- FLAGS / CANCELLATIONS (Admin SDK only) --------
       Written by server routes (POST /api/flags, cancel flows). Clients may
       not read; admin escape hatch only. */
    match /flags/{id} {
      allow read, write: if request.auth.token.admin == true;
    }
    match /cancellations/{id} {
      allow read, write: if request.auth.token.admin == true;
    }

    /* -------- RATE LIMITS (Admin SDK only) -------- */
    match /rateLimits/{id} {
      allow read, write: if false;
    }

    /* -------- SETTINGS (admin-managed) -------- */
    match /settings/{doc} {
      allow read: if isSignedIn();
      allow write: if request.auth.token.admin == true;
    }

    /* -------- CHAT (as you already had) -------- */
    function chatDoc(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId));
    }
    function isChatParticipant(chatId) {
      return isSignedIn() && request.auth.uid in chatDoc(chatId).data.userIds;
    }
    function chatIsOpen(chatId) {
      return 'expiresAt' in chatDoc(chatId).data
             && request.time < chatDoc(chatId).data.expiresAt;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant(chatId);
      allow create: if isSignedIn()
                    && request.resource.data.userIds is list
                    && request.resource.data.userIds.size() >= 2
                    && request.auth.uid in request.resource.data.userIds
                    && request.resource.data.expiresAt is timestamp
                    && request.resource.data.expiresAt > request.time;
      allow update: if isChatParticipant(chatId)
                    && request.resource.data.userIds == resource.data.userIds
                    && request.resource.data.expiresAt is timestamp;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
                      && chatIsOpen(chatId)
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }
  }
}
