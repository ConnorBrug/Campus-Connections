/**
 * @fileoverview Firestore Security Rules for Ride Sharing App
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and trip requests.
 * Matches are accessible to participating users.
 * Chats and chat messages are restricted to participating users.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only to the user themselves.
 * - /tripRequests/{tripId}: Trip requests, owned by a user.
 * - /matches/{matchId}: Match details shared between two users, with denormalized participant data.
 * - /chats/{chatId}: Chat metadata.
 * - /chats/{chatId}/messages/{messageId}: Chat messages within a specific chat.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data.
 * - Users can only create, update, or delete their own trip requests.
 * - Matches are readable and writable by participating users.
 * - Chat messages are readable and writable by participating users.
 * - User listing is disallowed for privacy.
 *
 * Denormalization for Authorization:
 * - The `/matches/{matchId}` document contains a `participantIds` array to efficiently check user authorization without additional reads.
 * - The `/matches/{matchId}` document contains a `participants` map to store relevant trip details for each user participating in the match.
 *
 * Structural Segregation:
 * - Drafts vs. Published Content: Not applicable in this data model.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     * @allow (get, create, update, delete) if the requesting user is the owner of the profile.
     * @deny (get, create, update, delete) if the requesting user is not the owner of the profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      // Helper function to check if the requesting user is the owner
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Helper function to check if the requesting user is the owner, with existence check.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      // Only allow authenticated users
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is not allowed

      // Self-creation: Allow create if the user ID matches the authenticated user's ID.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;

      // On Update: Enforce immutability of the user ID.
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;

      //Only the user can delete their own profile
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to trip requests.
     * @path /tripRequests/{tripId}
     * @allow (get, create, update, delete) if the requesting user is the owner of the trip request.
     * @deny (get, create, update, delete) if the requesting user is not the owner of the trip request.
     * @principle Enforces document ownership for writes.
     */
    match /tripRequests/{tripId} {
      // Helper function to check if the requesting user is the owner of the trip request
      function isTripOwner(userId) {
        return request.auth.uid == userId;
      }

        // Helper function to check if the requesting user is the owner, with existence check.
        function isExistingTripOwner(userId) {
          return isTripOwner(userId) && resource != null;
        }

      // Only allow authenticated users
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();

      // Validate the trip request's user ID on create.
      allow create: if isSignedIn() && isTripOwner(request.resource.data.userId);
      allow update: if isExistingTripOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingTripOwner(resource.data.userId);
    }

    /**
     * @description Controls access to match details.
     * @path /matches/{matchId}
     * @allow (get, list, create, update, delete) if the requesting user is a participant in the match.
     * @deny (get, list, create, update, delete) if the requesting user is not a participant in the match.
     * @principle Enforces shared access between matched users.
     */
    match /matches/{matchId} {
      // Helper function to check if the requesting user is a participant in the match
      function isParticipant() {
        return request.auth.uid in resource.data.participantIds;
      }

        // Helper function to check if the requesting user is a participant in the match, with existence check
        function isExistingParticipant() {
          return isParticipant() && resource != null;
        }

      // Only allow authenticated users
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isParticipant();
      allow list: if isSignedIn();
      allow create: if false; // Matches are not created directly by users
      allow update: if isExistingParticipant();
      allow delete: if false; // Matches are not deleted directly by users
    }

        /**
         * @description Controls access to chat metadata.
         * @path /chats/{chatId}
         */
        match /chats/{chatId} {
            function isSignedIn() {
                return request.auth != null;
            }

            function isChatParticipant() {
                return request.auth.uid in resource.data.userIds;
            }

            allow get: if isSignedIn() && isChatParticipant();
            allow list: if false; // Chats are not publically listable.
            allow create: if false; // Chat creation should be handled by backend functions.
            allow update: if false;
            allow delete: if false;

            /**
             * @description Controls access to chat messages within a chat.
             * @path /chats/{chatId}/messages/{messageId}
             */
            match /messages/{messageId} {
                function isSignedIn() {
                    return request.auth != null;
                }

                function isChatParticipant() {
                    return get(/databases/$(database)/documents/chats/$(chatId)).data.userIds.hasAny([request.auth.uid]);
                }

                allow get: if isSignedIn() && isChatParticipant();
                allow list: if isSignedIn() && isChatParticipant();
                allow create: if isSignedIn() && isChatParticipant() && request.resource.data.senderId == request.auth.uid;
                allow update: if false;
                allow delete: if false;
            }
        }
  }
}