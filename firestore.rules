
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // UTILITY FUNCTIONS
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // RULES
    match /users/{userId} {
      allow read;
      allow write: if isOwner(userId);
    }
    
    match /tripRequests/{tripId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid
                    && !request.resource.data.isBanned;
      
      allow update, delete: if resource.data.userId == request.auth.uid
                                || (resource.data.matchedUserId != null && resource.data.matchedUserId == request.auth.uid);
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.userIds;
      
      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.userIds;
      }
    }
    
     match /flags/{flagId} {
      allow create: if request.auth != null && request.resource.data.flaggerId == request.auth.uid;
    }
  }
}
