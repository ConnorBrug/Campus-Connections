/**
 * @fileoverview Firestore Security Rules for Ride Sharing App
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for profiles and trip requests,
 * and a shared-access model for matches and chats.  It prioritizes authorization
 * and assumes data validation will occur in application code or Firebase Functions.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only to the user themselves.
 * - /tripRequests/{tripId}: Trip requests, accessible only to the user who created them.
 * - /matches/{matchId}: Matches between users, accessible to the matched users.
 * - /chats/{chatId}: Chat metadata, accessible to the participating users.
 * - /chats/{chatId}/messages/{messageId}: Chat messages, accessible to participating users.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data.
 * - Users can only create, read, update, and delete their own trip requests.
 * - Matches are accessible to participating users.
 * - Chats and chat messages are accessible to participating users.
 * - List operations are generally restricted to owners for user-specific data.
 *
 * Denormalization for Authorization:
 * - Matches denormalize participant IDs into the `participantIds` array to simplify access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get, update, delete) if the user is the owner of the profile.
     * @allow (create) if the user's UID matches the userId.
     * @deny (get, update, delete) if the user is not the owner.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Controls access to trip request documents.
     * @path /tripRequests/{tripId}
     * @allow (get, update, delete) if the user is the owner of the trip request.
     * @allow (create) if the user is authenticated.
     * @deny (get, update, delete) if the user is not the owner.
     * @principle Enforces document ownership for trip requests.
     */
    match /tripRequests/{tripId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.userId;
      }

      allow get: if isOwner();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    /**
     * @description Controls access to match documents.
     * @path /matches/{matchId}
     * @allow (get, update, delete) if the user is a participant in the match.
     * @allow (create) if the user is authenticated.
     * @deny (get, update, delete) if the user is not a participant.
     * @principle Enforces shared access based on participation in the match.
     */
    match /matches/{matchId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isParticipant() {
        return isSignedIn() && resource.data.participantIds.hasAny([request.auth.uid]);
      }

      allow get: if isParticipant();
      allow list: if false;
      allow create: if false; // Matches should be created by backend
      allow update: if isParticipant();
      allow delete: if false; // Matches should be deleted by backend
    }

    /**
     * @description Controls access to chat documents.
     * @path /chats/{chatId}
     * @allow (get, update, delete) if the user is a member of the chat.
     * @allow (create) if the user is authenticated.
     * @deny (get, update, delete) if the user is not a member.
     * @principle Enforces shared access based on membership in the chat.
     */
    match /chats/{chatId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isChatMember() {
          return isSignedIn() && resource.data.userIds.hasAny([request.auth.uid]);
      }

      allow get: if isChatMember();
      allow list: if false;
      allow create: if false;
      allow update: if isChatMember();
      allow delete: if isChatMember();

      /**
       * @description Controls access to chat message documents.
       * @path /chats/{chatId}/messages/{messageId}
       * @allow (get, update, delete) if the user is a member of the chat.
       * @allow (create) if the user is a member of the chat.
       * @deny (get, update, delete) if the user is not a member.
       * @principle Enforces shared access based on membership in the chat.
       */
      match /messages/{messageId} {
        function isSignedIn() {
          return request.auth != null;
        }

         function isChatMember() {
            return isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userIds.hasAny([request.auth.uid]);
        }

        allow get: if isChatMember();
        allow list: if false;
        allow create: if isChatMember();
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}