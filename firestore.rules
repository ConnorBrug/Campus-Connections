/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles and a shared access model for chats.
 *
 * Data Structure:
 * - /users/{userId}: Stores public user profiles. Each user can only read/write their own profile.
 * - /tripRequests/{tripId}: Stores trip requests.  No write rules provided for trip requests.
 * - /chats/{chatId}: Stores chat metadata, including user IDs. Only members of the chat can read/write.
 * - /chats/{chatId}/messages/{messageId}: Stores chat messages. Only members of the chat can read/write.
 *
 * Key Security Decisions:
 * - User profiles are strictly private; users can only access their own profiles.
 * - Chats and messages are accessible only to members of the chat, using a shared access pattern based on the 'userIds' array.
 * - Listing of user profiles is disallowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) User 'user_abc' can create their profile if request.auth.uid == userId.
     * @allow (get) User 'user_abc' can read their profile.
     * @allow (update) User 'user_abc' can update their profile.
     * @allow (delete) User 'user_abc' can delete their profile.
     * @deny (create) User 'user_xyz' cannot create a profile for 'user_abc'.
     * @deny (get) User 'user_xyz' cannot read the profile of 'user_abc'.
     * @deny (update) User 'user_xyz' cannot update the profile of 'user_abc'.
     * @deny (delete) User 'user_xyz' cannot delete the profile of 'user_abc'.
     * @principle Enforces document ownership for writes and restricts access to a user's own data.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && exists(resource);
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to trip request documents.
     * @path /tripRequests/{tripId}
     * @allow (get) Allow anyone to read a trip request.
     * @allow (list) Allow anyone to list trip requests.
     * @deny (create) No one can create a trip request through security rules.
     * @deny (update) No one can update a trip request through security rules.
     * @deny (delete) No one can delete a trip request through security rules.
     * @principle Allows public read access, but restricts write access.
     */
    match /tripRequests/{tripId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to chat documents.
     * @path /chats/{chatId}
     * @allow (create) A user can create a chat if they are one of the userIds.
     * @allow (get) A user can read a chat if they are one of the userIds.
     * @allow (update) A user can update a chat if they are one of the userIds and only modifying fields that don't affect ownership
     * @allow (delete) A user can delete a chat if they are one of the userIds.
     * @deny (create) User 'user_xyz' cannot create a chat if they are not one of the userIds.
     * @deny (get) User 'user_xyz' cannot read the chat if they are not one of the userIds.
     * @deny (update) User 'user_xyz' cannot update the chat if they are not one of the userIds.
     * @deny (delete) User 'user_xyz' cannot delete the chat if they are not one of the userIds.
     * @principle Enforces shared access based on the 'userIds' array.
     */
    match /chats/{chatId} {
      function isChatMember() {
        return request.auth != null && request.resource.data.userIds is list && request.resource.data.userIds.hasAny([request.auth.uid]);
      }

      function isExistingChatMember() {
          return request.auth != null && resource.data.userIds is list && resource.data.userIds.hasAny([request.auth.uid]);
      }

      allow get, list: if isExistingChatMember();
      allow create: if isChatMember();
      allow update: if isExistingChatMember();
      allow delete: if isExistingChatMember();
    }

    /**
     * @description Controls access to chat message documents.
     * @path /chats/{chatId}/messages/{messageId}
     * @allow (create) A user can create a message if they are a member of the chat.
     * @allow (get) A user can read a message if they are a member of the chat.
     * @allow (update) A user can update a message if they are a member of the chat.
     * @allow (delete) A user can delete a message if they are a member of the chat.
     * @deny (create) User 'user_xyz' cannot create a message if they are not a member of the chat.
     * @deny (get) User 'user_xyz' cannot read the message if they are not a member of the chat.
     * @deny (update) User 'user_xyz' cannot update the message if they are not a member of the chat.
     * @deny (delete) User 'user_xyz' cannot delete the message if they are not a member of the chat.
     * @principle Enforces shared access based on the parent chat's 'userIds' array.
     */
    match /chats/{chatId}/messages/{messageId} {
        function isChatMember() {
            return request.auth != null && get(/databases/$(database)/documents/chats/$(chatId)).data.userIds is list && get(/databases/$(database)/documents/chats/$(chatId)).data.userIds.hasAny([request.auth.uid]);
        }
      allow get, list: if isChatMember();
      allow create: if isChatMember();
      allow update: if isChatMember();
      allow delete: if isChatMember();
    }
  }
}