/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a mixed security model, balancing open read access with secured write access based on ownership.
 *
 * Data Structure:
 * - /users/{userId}: Stores public user profiles.
 * - /tripRequests/{tripId}: Stores trip requests made by users.
 * - /chats/{chatId}: Stores metadata for chat sessions.
 * - /chats/{chatId}/messages/{messageId}: Stores individual chat messages.
 *
 * Key Security Decisions:
 * - User profiles are publicly readable, but only the owner can modify their own profile.
 * - Trip requests are publicly readable and only the owner can modify their own request.
 * - Chats and chat messages are only accessible to authenticated users.
 *
 * Denormalization for Authorization:
 * - The `TripRequest` entity requires a `userId` field for ownership validation on writes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read user profiles, but only the owner can modify their profile.
     * @path /users/{userId}
     * @allow (get, list): Any user can read user profiles.
     * @allow (create): The user with ID {userId} can create their profile.
     * @allow (update, delete): The user with ID {userId} can update or delete their profile.
     * @deny (create): A user cannot create a profile with an ID different from their own.
     * @deny (update, delete): A user cannot update or delete another user's profile.
     * @principle Allows public reads, but restricts writes to the owner. Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Allows anyone to read trip requests, but only the owner can modify their own request.
     * @path /tripRequests/{tripId}
     * @allow (get, list): Any user can read trip requests.
     * @allow (create): The user can create their own trip request if the userId matches.
     * @allow (update, delete): The owner can update or delete their trip request.
     * @deny (create): A user cannot create a trip request with a userId different from their own.
     * @deny (update, delete): A user cannot update or delete another user's trip request.
     * @principle Allows public reads, but restricts writes to the owner. Enforces document ownership for writes.
     */
    match /tripRequests/{tripId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.userId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.userId);
    }

    /**
     * @description Allows authenticated users to read and create chats.
     * @path /chats/{chatId}
     */
    match /chats/{chatId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Allows authenticated users to read and create messages within a specific chat.
     * @path /chats/{chatId}/messages/{messageId}
     */
    match /chats/{chatId}/messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if false;
        allow delete: if false;
    }

    // ---- Helper functions ----

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user ID matches the authenticated user's ID.
     * @param {string} userId The user ID to check.
     * @return {bool} True if the user ID matches the authenticated user's ID, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && userId == request.auth.uid;
    }

   /**
    * @description Combines ownership and existence check for update and delete operations
    * @param {string} userId The user ID to check for ownership
    * @return {bool} True if the user is the owner and the resource exists, false otherwise
    */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}